  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "vite": "^5.0.0",
    "eslint": "^8.50.0",
    "eslint-plugin-react": "^7.33.0",
    "prettier": "^3.0.0",
    "vitest": "^1.0.0"
  }
}
